# CMS Panel — security & clean URLs
# Increase upload limits (if mod_php is used)
<IfModule mod_php.c>
    php_value post_max_size 128M
    php_value upload_max_filesize 128M
    php_value memory_limit 256M
</IfModule>
<IfModule mod_php7.c>
    php_value post_max_size 128M
    php_value upload_max_filesize 128M
    php_value memory_limit 256M
</IfModule>

Options -Indexes

# Block direct access to data directories and sensitive files
<IfModule mod_rewrite.c>
    RewriteEngine On

    # Homepage at / (internal rewrite; URL bar stays without index.php)
    RewriteRule ^$ index.php [L]

    # Canonical URL: direct /index.php requests → / (THE_REQUEST avoids loops on internal rewrites)
    RewriteCond %{THE_REQUEST} ^[A-Z]{3,9}\s[^\s]+\sHTTP/ [NC]
    RewriteCond %{THE_REQUEST} index\.php [NC]
    RewriteRule ^index\.php$ ./ [R=301,L]

    RewriteRule ^pages_data/ - [F,L]
    RewriteRule ^users_data/ - [F,L]

    # If the CMS lives in a subfolder, Apache usually sets the per-dir prefix automatically.
    # If rewrites fail on your host, try uncommenting and setting RewriteBase to your folder path.
    # RewriteBase /your-subfolder/

    RewriteCond %{REQUEST_FILENAME} -f [OR]
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]

    RewriteRule ^robots\.txt$ robots.php [L]
    RewriteRule ^sitemap\.xml$ sitemap.php [L]

    # Smart Media Routing: Check uploads/ if file not in root
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{DOCUMENT_ROOT}/uploads/$1 -f
    RewriteRule ^([^/]+\.(png|jpg|jpeg|gif|webp|svg|pdf|mp4|mp3|zip))$ uploads/$1 [L]

    # Admin rewrite: /viv-admin → viv-admin.php
    RewriteRule ^viv-admin$ viv-admin.php [L,QSA]

    # Same pattern as CMS_INNER_PAGE_URL_REGEX in cms_routing.php (and router.php for php -S).
    RewriteRule ^([a-z0-9][a-z0-9\-]*)/?$ view.php?page=$1 [L,QSA]
</IfModule>

<FilesMatch "\.(json)$">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Deny from all
    </IfModule>
</FilesMatch>
