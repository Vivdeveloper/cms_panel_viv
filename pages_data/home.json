{"slug":"home","title":"Home","html":"<!DOCTYPE html>\r\n<html lang=\"en\">\r\n\r\n<head>\r\n    <meta charset=\"UTF-8\">\r\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\r\n    <title>Customer Care REPAIRS | Professional Appliance Repair Services<\/title>\r\n    <meta name=\"description\"\r\n        content=\"Certified appliance repair technicians for washing machines, refrigerators, TVs, and more. Fast, reliable, and affordable same-day service.\">\r\n\r\n    <!-- Google Fonts: Poppins -->\r\n    <link rel=\"preconnect\" href=\"https:\/\/fonts.googleapis.com\">\r\n    <link rel=\"preconnect\" href=\"https:\/\/fonts.gstatic.com\" crossorigin>\r\n    <link href=\"https:\/\/fonts.googleapis.com\/css2?family=Poppins:wght@300;400;500;600;700;800&display=swap\"\r\n        rel=\"stylesheet\">\r\n\r\n    <!-- Font Awesome -->\r\n    <link rel=\"stylesheet\" href=\"https:\/\/cdnjs.cloudflare.com\/ajax\/libs\/font-awesome\/6.4.0\/css\/all.min.css\">\r\n\r\n    <style>\r\n        :root {\r\n            --primary: #0061f2;\r\n            --primary-dark: #0048b3;\r\n            --secondary: #69707a;\r\n            --accent: #f4a100;\r\n            --success: #00ac69;\r\n            --bg-light: #f2f5f9;\r\n            --bg-white: #ffffff;\r\n            --text-dark: #212832;\r\n            --text-muted: #69707a;\r\n            --border: #e2e8f0;\r\n            --radius: 8px;\r\n            --shadow-sm: 0 0.125rem 0.25rem rgba(33, 40, 50, 0.075);\r\n            --shadow-md: 0 0.5rem 1rem rgba(33, 40, 50, 0.1);\r\n            --transition: all 0.2s ease-in-out;\r\n        }\r\n\r\n        * {\r\n            margin: 0;\r\n            padding: 0;\r\n            box-sizing: border-box;\r\n            scroll-behavior: smooth;\r\n        }\r\n\r\n        body {\r\n            font-family: 'Poppins', sans-serif;\r\n            color: var(--text-dark);\r\n            background-color: var(--bg-white);\r\n            line-height: 1.6;\r\n        }\r\n\r\n        h1,\r\n        h2,\r\n        h3,\r\n        h4 {\r\n            font-weight: 700;\r\n            color: var(--text-dark);\r\n            line-height: 1.2;\r\n        }\r\n\r\n        a {\r\n            text-decoration: none;\r\n            color: inherit;\r\n            transition: var(--transition);\r\n        }\r\n\r\n        .container {\r\n            width: 100%;\r\n            max-width: 1140px;\r\n            margin: 0 auto;\r\n            padding: 0 1.5rem;\r\n        }\r\n\r\n        .section-padding {\r\n            padding: 5rem 0;\r\n        }\r\n\r\n        .btn {\r\n            display: inline-block;\r\n            padding: 0.8rem 1.8rem;\r\n            border-radius: var(--radius);\r\n            font-weight: 600;\r\n            cursor: pointer;\r\n            transition: var(--transition);\r\n            border: none;\r\n            text-align: center;\r\n        }\r\n\r\n        .btn-primary {\r\n            background-color: var(--primary);\r\n            color: white;\r\n        }\r\n\r\n        .btn-primary:hover {\r\n            background-color: var(--primary-dark);\r\n            transform: translateY(-2px);\r\n        }\r\n\r\n        \/* Header *\/\r\n        header {\r\n            position: fixed;\r\n            top: 0;\r\n            left: 0;\r\n            width: 100%;\r\n            background-color: var(--bg-white);\r\n            z-index: 1000;\r\n            box-shadow: var(--shadow-sm);\r\n            height: 80px;\r\n            display: flex;\r\n            align-items: center;\r\n        }\r\n\r\n        nav {\r\n            display: flex;\r\n            justify-content: space-between;\r\n            align-items: center;\r\n            width: 100%;\r\n        }\r\n\r\n        .logo {\r\n            font-size: 1.4rem;\r\n            font-weight: 800;\r\n            color: var(--primary);\r\n            display: flex;\r\n            align-items: center;\r\n            gap: 0.5rem;\r\n            white-space: nowrap;\r\n        }\r\n\r\n        .logo span {\r\n            color: var(--text-dark);\r\n        }\r\n\r\n        .nav-links {\r\n            display: flex;\r\n            gap: 2rem;\r\n        }\r\n\r\n        .nav-links a {\r\n            font-weight: 500;\r\n            color: var(--text-muted);\r\n            font-size: 0.95rem;\r\n        }\r\n\r\n        .nav-links a:hover {\r\n            color: var(--primary);\r\n        }\r\n\r\n        .menu-toggle {\r\n            display: none;\r\n            font-size: 1.5rem;\r\n            color: var(--text-dark);\r\n            cursor: pointer;\r\n        }\r\n\r\n        \/* Hero Section (Split Screen) *\/\r\n        .hero {\r\n            height: 90vh;\r\n            min-height: 600px;\r\n            background-color: var(--bg-light);\r\n            border-bottom: 1px solid var(--border);\r\n            overflow: hidden;\r\n            display: flex;\r\n            align-items: center;\r\n        }\r\n\r\n        .hero-row {\r\n            display: flex;\r\n            width: 100%;\r\n            height: 100%;\r\n            align-items: stretch;\r\n        }\r\n\r\n        .hero-image {\r\n            flex: 1;\r\n            position: relative;\r\n            overflow: hidden;\r\n        }\r\n\r\n        .hero-image img {\r\n            width: 100%;\r\n            height: 100%;\r\n            object-fit: cover;\r\n        }\r\n\r\n        .hero-content {\r\n            flex: 1;\r\n            padding: 5rem 8% 5rem 5rem;\r\n            display: flex;\r\n            flex-direction: column;\r\n            justify-content: center;\r\n            background: var(--bg-white);\r\n        }\r\n\r\n        .hero-title {\r\n            font-size: 3rem;\r\n            margin-bottom: 1.5rem;\r\n            color: var(--text-dark);\r\n            line-height: 1.2;\r\n        }\r\n\r\n        .hero-subtitle {\r\n            font-size: 1.1rem;\r\n            color: var(--text-muted);\r\n            margin-bottom: 2.5rem;\r\n        }\r\n\r\n        \/* Section Headings *\/\r\n        .section-header {\r\n            text-align: center;\r\n            margin-bottom: 4rem;\r\n        }\r\n\r\n        .section-header h2 {\r\n            font-size: 2.2rem;\r\n            margin-bottom: 1rem;\r\n            position: relative;\r\n            padding-bottom: 1rem;\r\n        }\r\n\r\n        .section-header h2::after {\r\n            content: \"\";\r\n            position: absolute;\r\n            bottom: 0;\r\n            left: 50%;\r\n            transform: translateX(-50%);\r\n            width: 60px;\r\n            height: 4px;\r\n            background-color: var(--primary);\r\n            border-radius: 2px;\r\n        }\r\n\r\n        \/* Services Grid *\/\r\n        .services-grid {\r\n            display: grid;\r\n            grid-template-columns: repeat(3, 1fr);\r\n            gap: 2rem;\r\n        }\r\n\r\n        .service-card {\r\n            background-color: var(--bg-white);\r\n            border: 1px solid var(--border);\r\n            border-radius: var(--radius);\r\n            overflow: hidden;\r\n            transition: var(--transition);\r\n        }\r\n\r\n        .service-card:hover {\r\n            box-shadow: var(--shadow-md);\r\n            transform: translateY(-5px);\r\n            border-color: var(--primary);\r\n        }\r\n\r\n        .service-img-wrapper {\r\n            height: 200px;\r\n            overflow: hidden;\r\n        }\r\n\r\n        .service-img-wrapper img {\r\n            width: 100%;\r\n            height: 100%;\r\n            object-fit: cover;\r\n        }\r\n\r\n        .service-info {\r\n            padding: 1.5rem;\r\n        }\r\n\r\n        .service-info h3 {\r\n            font-size: 1.25rem;\r\n            margin-bottom: 1rem;\r\n        }\r\n\r\n        .service-info p {\r\n            font-size: 0.9rem;\r\n            color: var(--text-muted);\r\n            margin-bottom: 1.5rem;\r\n        }\r\n\r\n        .issues-list {\r\n            list-style: none;\r\n            font-size: 0.85rem;\r\n            color: var(--text-muted);\r\n        }\r\n\r\n        .issues-list li {\r\n            margin-bottom: 0.5rem;\r\n            display: flex;\r\n            align-items: center;\r\n            gap: 0.5rem;\r\n        }\r\n\r\n        .issues-list li i {\r\n            color: var(--success);\r\n            font-size: 0.8rem;\r\n        }\r\n\r\n        \/* About Section *\/\r\n        .about-row {\r\n            display: flex;\r\n            align-items: flex-start;\r\n            \/* Align to top as per professional standards for long text *\/\r\n            gap: 5rem;\r\n        }\r\n\r\n        .about-image {\r\n            flex: 1;\r\n        }\r\n\r\n        .about-image img {\r\n            width: 100%;\r\n            height: auto;\r\n            border-radius: var(--radius);\r\n            box-shadow: var(--shadow-md);\r\n        }\r\n\r\n        .about-content {\r\n            flex: 1;\r\n            padding-top: 1rem;\r\n        }\r\n\r\n        .about-content h2 {\r\n            font-size: 2.25rem;\r\n            margin-bottom: 2rem;\r\n            line-height: 1.25;\r\n        }\r\n\r\n        .about-content p {\r\n            color: var(--text-muted);\r\n            font-size: 1rem;\r\n            margin-bottom: 2.5rem;\r\n        }\r\n\r\n        .about-features {\r\n            display: grid;\r\n            grid-template-columns: 1fr 1fr;\r\n            gap: 2rem;\r\n        }\r\n\r\n        .feature-item {\r\n            display: flex;\r\n            gap: 1.25rem;\r\n            align-items: flex-start;\r\n        }\r\n\r\n        .feature-icon {\r\n            color: var(--primary);\r\n            font-size: 1.5rem;\r\n            padding-top: 0.25rem;\r\n        }\r\n\r\n        .feature-text h4 {\r\n            font-size: 1.1rem;\r\n            margin-bottom: 0.5rem;\r\n        }\r\n\r\n        .feature-text p {\r\n            font-size: 0.875rem;\r\n            color: var(--text-muted);\r\n            margin-bottom: 0;\r\n            line-height: 1.5;\r\n        }\r\n\r\n        \/* Why Us Section *\/\r\n        .bg-light {\r\n            background-color: var(--bg-light);\r\n        }\r\n\r\n        .why-us-grid {\r\n            display: grid;\r\n            grid-template-columns: repeat(3, 1fr);\r\n            gap: 2.5rem;\r\n        }\r\n\r\n        .why-item {\r\n            text-align: center;\r\n        }\r\n\r\n        .why-icon {\r\n            width: 70px;\r\n            height: 70px;\r\n            background-color: var(--bg-white);\r\n            color: var(--primary);\r\n            border-radius: 50%;\r\n            display: flex;\r\n            align-items: center;\r\n            justify-content: center;\r\n            font-size: 1.8rem;\r\n            margin: 0 auto 1.5rem;\r\n            box-shadow: var(--shadow-sm);\r\n        }\r\n\r\n        \/* Testimonials *\/\r\n        .testimonial-grid {\r\n            display: grid;\r\n            grid-template-columns: repeat(2, 1fr);\r\n            gap: 2rem;\r\n        }\r\n\r\n        .testimonial-card {\r\n            background-color: var(--bg-white);\r\n            padding: 2.5rem;\r\n            border-radius: var(--radius);\r\n            border: 1px solid var(--border);\r\n            position: relative;\r\n        }\r\n\r\n        \/* FAQ *\/\r\n        .faq-accordion {\r\n            max-width: 800px;\r\n            margin: 0 auto;\r\n        }\r\n\r\n        .faq-item {\r\n            margin-bottom: 1rem;\r\n            border: 1px solid var(--border);\r\n            border-radius: var(--radius);\r\n        }\r\n\r\n        .faq-header {\r\n            padding: 1.25rem;\r\n            cursor: pointer;\r\n            display: flex;\r\n            justify-content: space-between;\r\n            align-items: center;\r\n            font-weight: 600;\r\n        }\r\n\r\n        .faq-body {\r\n            padding: 0 1.25rem 1.25rem;\r\n            color: var(--text-muted);\r\n            display: none;\r\n        }\r\n\r\n        \/* Footer *\/\r\n        footer {\r\n            background-color: #1a202c;\r\n            color: #cbd5e0;\r\n            padding: 5rem 0 2rem;\r\n        }\r\n\r\n        .footer-grid {\r\n            display: grid;\r\n            grid-template-columns: 1.5fr 1fr 1fr 1fr;\r\n            gap: 3rem;\r\n            margin-bottom: 4rem;\r\n        }\r\n\r\n        .footer-grid h4 {\r\n            color: white;\r\n            margin-bottom: 1.5rem;\r\n            font-size: 1.1rem;\r\n        }\r\n\r\n        .footer-links li {\r\n            margin-bottom: 0.8rem;\r\n            list-style: none;\r\n        }\r\n\r\n        .footer-links a:hover {\r\n            color: white;\r\n        }\r\n\r\n        .footer-bottom {\r\n            padding-top: 2rem;\r\n            border-top: 1px solid #2d3748;\r\n            text-align: center;\r\n            font-size: 0.85rem;\r\n        }\r\n\r\n        \/* Responsive *\/\r\n        @media (max-width: 992px) {\r\n            .hero {\r\n                height: auto;\r\n                padding-top: 80px;\r\n            }\r\n\r\n            .hero-row {\r\n                flex-direction: column;\r\n                width: 100%;\r\n                border: 0;\r\n            }\r\n\r\n            .hero-image {\r\n                height: 400px;\r\n                width: 100%;\r\n                order: 1;\r\n            }\r\n\r\n            .hero-image img {\r\n                border-radius: 0;\r\n                box-shadow: none;\r\n            }\r\n\r\n            .hero-content {\r\n                padding: 4rem 1.5rem;\r\n                text-align: center;\r\n                order: 2;\r\n                width: 100%;\r\n            }\r\n\r\n            .hero-title {\r\n                font-size: 2.25rem;\r\n            }\r\n\r\n            .services-grid,\r\n            .why-us-grid {\r\n                grid-template-columns: repeat(2, 1fr);\r\n            }\r\n\r\n            .testimonial-grid {\r\n                grid-template-columns: 1fr;\r\n            }\r\n\r\n            .footer-grid {\r\n                grid-template-columns: 1fr 1fr;\r\n            }\r\n\r\n            .about-row {\r\n                flex-direction: column;\r\n                text-align: center;\r\n                gap: 3rem;\r\n            }\r\n\r\n            .about-content {\r\n                padding-top: 0;\r\n            }\r\n\r\n            .about-features {\r\n                grid-template-columns: 1fr;\r\n                gap: 1.5rem;\r\n                text-align: left;\r\n            }\r\n        }\r\n\r\n        @media (max-width: 768px) {\r\n            header .container {\r\n                padding: 0 1.5rem;\r\n                max-width: 100%;\r\n            }\r\n\r\n            header {\r\n                height: 75px;\r\n            }\r\n\r\n            .nav-btn {\r\n                display: none;\r\n            }\r\n\r\n            .menu-toggle {\r\n                display: block;\r\n                z-index: 1001;\r\n            }\r\n\r\n            .nav-links {\r\n                position: fixed;\r\n                top: 75px;\r\n                left: -100%;\r\n                width: 100%;\r\n                height: calc(100vh - 75px);\r\n                background-color: var(--bg-white);\r\n                flex-direction: column;\r\n                display: flex !important;\r\n                align-items: center;\r\n                padding-top: 4rem;\r\n                transition: var(--transition);\r\n                z-index: 1000;\r\n                box-shadow: var(--shadow-sm);\r\n                gap: 2rem;\r\n            }\r\n\r\n            .nav-links.active {\r\n                left: 0;\r\n            }\r\n\r\n            .nav-links a {\r\n                font-size: 1.25rem;\r\n            }\r\n\r\n            .hero {\r\n                padding-top: 75px;\r\n            }\r\n\r\n            .hero-image {\r\n                height: 320px;\r\n            }\r\n\r\n            .hero-title {\r\n                font-size: 1.85rem;\r\n            }\r\n\r\n            .section-padding {\r\n                padding: 3.5rem 0;\r\n            }\r\n\r\n            .services-grid,\r\n            .why-us-grid,\r\n            .footer-grid {\r\n                grid-template-columns: 1fr;\r\n            }\r\n\r\n            .section-header h2 {\r\n                font-size: 1.75rem;\r\n            }\r\n        }\r\n    <\/style>\r\n<\/head>\r\n\r\n<body>\r\n\r\n    <!-- Header -->\r\n    <header>\r\n        <div class=\"container\">\r\n            <nav>\r\n                <a href=\"#\" class=\"logo\">\r\n                    <i class=\"fas fa-tools\"><\/i> <span>Customer Care REPAIRS<\/span>\r\n                <\/a>\r\n                <ul class=\"nav-links\">\r\n                    <li><a href=\"#home\">Home<\/a><\/li>\r\n                    <li><a href=\"#services\">Services<\/a><\/li>\r\n                    <li><a href=\"#about\">About<\/a><\/li>\r\n                    <li><a href=\"#faq\">FAQ<\/a><\/li>\r\n                <\/ul>\r\n                <div class=\"nav-btn\">\r\n                    <button class=\"btn btn-primary\" onclick=\"document.getElementById('services').scrollIntoView()\">Book\r\n                        Repair<\/button>\r\n                <\/div>\r\n                <!-- Menu Icon for Mobile -->\r\n                <div class=\"menu-toggle\">\r\n                    <i class=\"fas fa-bars\"><\/i>\r\n                <\/div>\r\n            <\/nav>\r\n        <\/div>\r\n    <\/header>\r\n\r\n    <main>\r\n        <!-- Hero -->\r\n        <section class=\"hero\" id=\"home\">\r\n            <div class=\"hero-row\">\r\n                <div class=\"hero-image\">\r\n                    <img src=\"uploads\/call-center-agents-at-work.jpeg\"\r\n                        alt=\"Professional Customer Support Ready to Help 24\/7\">\r\n                <\/div>\r\n                <div class=\"hero-content\">\r\n                    <h1 class=\"hero-title\">Reliable Appliance Repair at Your Doorstep!<\/h1>\r\n                    <p class=\"hero-subtitle\">10+ Years of Trusted Service. We specialize in quick and expert repairs for\r\n                        washing machines, refrigerators, TVs, and more.<\/p>\r\n                    <button class=\"btn btn-primary\" onclick=\"document.getElementById('services').scrollIntoView()\"\r\n                        style=\"width: fit-content;\">Explore Our Services<\/button>\r\n                <\/div>\r\n            <\/div>\r\n        <\/section>\r\n\r\n        <!-- Services -->\r\n        <section class=\"section-padding\" id=\"services\">\r\n            <div class=\"container\">\r\n                <div class=\"section-header\">\r\n                    <h2>Our Repair Services<\/h2>\r\n                    <p>Technician experts dedicated to bringing your appliances back to life.<\/p>\r\n                <\/div>\r\n\r\n                <div class=\"services-grid\">\r\n                    <!-- Washing Machine -->\r\n                    <div class=\"service-card\">\r\n                        <div class=\"service-img-wrapper\">\r\n                            <img src=\"uploads\/washing-machine-repair-technician.png\" alt=\"Washing Machine Repair\">\r\n                        <\/div>\r\n                        <div class=\"service-info\">\r\n                            <h3>Washing Machine Repair<\/h3>\r\n                            <p>Fast diagnostic and fix for all major brands of washing machines.<\/p>\r\n                            <ul class=\"issues-list\">\r\n                                <li><i class=\"fas fa-check\"><\/i> Not draining or spinning<\/li>\r\n                                <li><i class=\"fas fa-check\"><\/i> Strange noises or vibration<\/li>\r\n                                <li><i class=\"fas fa-check\"><\/i> Water leakage issues<\/li>\r\n                            <\/ul>\r\n                        <\/div>\r\n                    <\/div>\r\n\r\n                    <!-- Refrigerator -->\r\n                    <div class=\"service-card\">\r\n                        <div class=\"service-img-wrapper\">\r\n                            <img src=\"uploads\/refrigerator-repair-technician.png\" alt=\"Refrigerator Repair\">\r\n                        <\/div>\r\n                        <div class=\"service-info\">\r\n                            <h3>Refrigerator Repair<\/h3>\r\n                            <p>Expert cooling solutions to keep your food fresh and appliances running.<\/p>\r\n                            <ul class=\"issues-list\">\r\n                                <li><i class=\"fas fa-check\"><\/i> Not cooling or over-freezing<\/li>\r\n                                <li><i class=\"fas fa-check\"><\/i> Gas charging & Gas Leak<\/li>\r\n                                <li><i class=\"fas fa-check\"><\/i> Unusual compressor sounds<\/li>\r\n                            <\/ul>\r\n                        <\/div>\r\n                    <\/div>\r\n\r\n                    <!-- TV -->\r\n                    <div class=\"service-card\">\r\n                        <div class=\"service-img-wrapper\">\r\n                            <img src=\"uploads\/technician-repairing-back-of-wall-tv.png\" alt=\"TV Repair\">\r\n                        <\/div>\r\n                        <div class=\"service-info\">\r\n                            <h3>TV Repair<\/h3>\r\n                            <p>Specialized repair for LED, LCD, and Smart TVs of all sizes.<\/p>\r\n                            <ul class=\"issues-list\">\r\n                                <li><i class=\"fas fa-check\"><\/i> No power or display issues<\/li>\r\n                                <li><i class=\"fas fa-check\"><\/i> Sound problems or flickering<\/li>\r\n                                <li><i class=\"fas fa-check\"><\/i> Screen & remote connectivity<\/li>\r\n                            <\/ul>\r\n                        <\/div>\r\n                    <\/div>\r\n\r\n                    <!-- Dryer -->\r\n                    <div class=\"service-card\">\r\n                        <div class=\"service-img-wrapper\">\r\n                            <img src=\"uploads\/technician-red-uniform-repairing-washer.jpg\" alt=\"Dryer Repair\">\r\n                        <\/div>\r\n                        <div class=\"service-info\">\r\n                            <h3>Dryer Repair<\/h3>\r\n                            <p>Quality maintenance for efficient and safe drying performance.<\/p>\r\n                            <ul class=\"issues-list\">\r\n                                <li><i class=\"fas fa-check\"><\/i> Not heating or drying properly<\/li>\r\n                                <li><i class=\"fas fa-check\"><\/i> Lint buildup & sensor fix<\/li>\r\n                                <li><i class=\"fas fa-check\"><\/i> Motor & belt replacement<\/li>\r\n                            <\/ul>\r\n                        <\/div>\r\n                    <\/div>\r\n\r\n                    <!-- Microwave -->\r\n                    <div class=\"service-card\">\r\n                        <div class=\"service-img-wrapper\">\r\n                            <img src=\"uploads\/repairman-fixing-built-in-microwave.jpg\" alt=\"Microwave Repair\">\r\n                        <\/div>\r\n                        <div class=\"service-info\">\r\n                            <h3>Microwave Repair<\/h3>\r\n                            <p>Safe and efficient electronic repairs for all microwave models.<\/p>\r\n                            <ul class=\"issues-list\">\r\n                                <li><i class=\"fas fa-check\"><\/i> Not heating or sparks<\/li>\r\n                                <li><i class=\"fas fa-check\"><\/i> Power failures or display errors<\/li>\r\n                                <li><i class=\"fas fa-check\"><\/i> Turntable & timer issues<\/li>\r\n                            <\/ul>\r\n                        <\/div>\r\n                    <\/div