        menuToggle.addEventListener('click', () => {\r\n            navLinks.classList.toggle('active');\r\n            \/\/ Toggle between hamburger and close icon\r\n            if (navLinks.classList.contains('active')) {\r\n                menuIcon.classList.remove('fa-bars');\r\n                menuIcon.classList.add('fa-times');\r\n            } else {\r\n                menuIcon.classList.remove('fa-times');\r\n                menuIcon.classList.add('fa-bars');\r\n            }\r\n        });\r\n\r\n        \/\/ Close menu when clicking a link (optional for UX)\r\n        document.querySelectorAll('.nav-links a').forEach(link => {\r\n            link.addEventListener('click', () => {\r\n                navLinks.classList.remove('active');\r\n                menuIcon.classList.remove('fa-times');\r\n                menuIcon.classList.add('fa-bars');\r\n            });\r\n        });\r\n\r\n        \/\/ FAQ Toggle\r\n        function toggleFaq(header) {\r\n            const body = header.nextElementSibling;\r\n            const icon = header.querySelector('i');\r\n            const isOpen = body.style.display === 'block';\r\n\r\n            \/\/ Close all\r\n            document.querySelectorAll('.faq-body').forEach(b => b.style.display = 'none');\r\n            document.querySelectorAll('.faq-header i').forEach(i => {\r\n                i.classList.remove('fa-chevron-up');\r\n                i.classList.add('fa-chevron-down');\r\n            });\r\n\r\n            if (!isOpen) {\r\n                body.style.display = 'block';\r\n                icon.classList.remove('fa-chevron-down');\r\n                icon.classList.add('fa-chevron-up');\r\n            }\r\n        }\r\n    <\/script>\r\n<\/body>\r\n\r\n<\/html>","css":"","is_home":true,"allow_in_menu":false,"status":"published","updated":"2026-03-29 09:28:09","meta_description":"","og_image":"","page_template":"canvas"}